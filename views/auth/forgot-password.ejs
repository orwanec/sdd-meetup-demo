<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/head', { title: 'Forgot Password · TaskFlow' }) %>
  </head>
  <body class="page page-auth">
    <main class="container">
      <div class="auth-card">
        <h1 class="page-title">Forgot Password</h1>
        <p class="form-help">Enter your email address and we will send reset instructions if an account exists.</p>

        <% if (error) { %>
          <p class="form-error" role="alert"><%= error %></p>
        <% } %>

        <form method="post" action="/auth/forgot-password">
          <%- include('../partials/csrf-field') %>
          <div class="form-group">
            <label for="email">Email</label>
            <input id="email" type="email" name="email" value="<%= email %>" required />
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-block">Send reset instructions</button>
          </div>
        </form>

        <div class="form-footer">
          <p><a href="/auth/login">Back to login</a></p>
        </div>
      </div>
    </main>
  </body>
</html>
