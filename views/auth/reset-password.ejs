<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/head', { title: 'Reset Password · TaskFlow' }) %>
  </head>
  <body class="page page-auth">
    <main class="container">
      <div class="auth-card">
        <h1 class="page-title">Reset Password</h1>
        <p class="form-help">Choose a new password with at least 8 characters.</p>

        <% if (error) { %>
          <p class="form-error" role="alert"><%= error %></p>
        <% } %>

        <form method="post" action="/auth/reset-password/<%= token %>">
          <%- include('../partials/csrf-field') %>
          <div class="form-group">
            <label for="password">New password</label>
            <input id="password" type="password" name="password" minlength="8" required />
          </div>

          <div class="form-group">
            <label for="password_confirm">Confirm new password</label>
            <input id="password_confirm" type="password" name="password_confirm" minlength="8" required />
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-block">Update password</button>
          </div>
        </form>

        <div class="form-footer">
          <p><a href="/auth/login">Back to login</a></p>
        </div>
      </div>
    </main>
  </body>
</html>
