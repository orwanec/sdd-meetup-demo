<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/head', { title: 'Login · TaskFlow' }) %>
  </head>
  <body class="page page-auth">
    <main class="container">
      <div class="auth-card">
        <h1 class="page-title">Login</h1>

        <% if (message) { %>
          <p class="alert alert-info"><%= message %></p>
        <% } %>

        <% if (error) { %>
          <p class="form-error" role="alert"><%= error %></p>
        <% } %>

        <form method="post" action="/auth/login">
          <%- include('../partials/csrf-field') %>
          <div class="form-group">
            <label for="email">Email</label>
            <input id="email" type="email" name="email" value="<%= email %>" required />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input id="password" type="password" name="password" required />
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-block">Login</button>
          </div>
        </form>

        <div class="form-footer">
          <p><a href="/auth/forgot-password">Forgot password?</a></p>
          <p><a href="/auth/register">Create an account</a></p>
          <p><a href="/dev/mailbox">Developer mailbox</a></p>
        </div>
      </div>
    </main>
  </body>
</html>
