<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/head', { title: 'Create Task · TaskFlow' }) %>
  </head>
  <body class="page page-form">
    <main class="container">
      <div class="form-card">
        <h1 class="page-title">Create Task</h1>

        <% if (error) { %>
          <p class="form-error" role="alert"><%= error %></p>
        <% } %>

        <form method="post" action="/tasks/create">
          <div class="form-group">
            <label for="title">Title</label>
            <input id="title" type="text" name="title" value="<%= title %>" required />
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="4"><%= description %></textarea>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Task</button>
            <a href="/dashboard" class="btn btn-secondary">Back to dashboard</a>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
