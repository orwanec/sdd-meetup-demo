<% if (!tasks || tasks.length === 0) { %>
  <p class="empty-state">No tasks yet.</p>
<% } else { %>
  <ul class="task-list">
    <% tasks.forEach(function (task) { %>
      <li class="task-item <%= task.status === 'completed' ? 'task-completed' : 'task-open' %>">
        <div>
          <strong><%= task.title %></strong>
          <% if (task.description) { %>
            <p><%= task.description %></p>
          <% } %>
        </div>
        <div class="task-meta">
          <% if (task.status === 'open') { %>
            <button type="button" class="btn btn-secondary" data-complete-task="<%= task.id %>">
              Mark complete
            </button>
          <% } else { %>
            <span class="task-status">Completed</span>
          <% } %>
        </div>
      </li>
    <% }); %>
  </ul>

  <script>
    document.querySelectorAll('[data-complete-task]').forEach(function (button) {
      button.addEventListener('click', async function () {
        const taskId = button.getAttribute('data-complete-task');
        await fetch('/tasks/' + taskId + '/complete', { method: 'POST' });
        window.location.reload();
      });
    });
  </script>
<% } %>
