{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "A lightweight task management application — TaskFlow MVP",
  "main": "server.js",
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "taskflow",
    "tasks",
    "sdd"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^7.2.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000,
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  }
}
