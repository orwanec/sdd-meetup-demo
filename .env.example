# Server Configuration
PORT=3000
NODE_ENV=development

# Session Configuration
# Required in production — use a long random string (see DEPLOYMENT.md)
SESSION_SECRET=change-me-in-production
# Session cookie max age in milliseconds (default: 1 hour)
SESSION_TIMEOUT=3600000

# Database Configuration
# Use :memory: for ephemeral test databases
DB_PATH=./data/taskflow.db

# Application base URL for password reset links
APP_BASE_URL=http://localhost:3000

# CORS (reserved for future API clients — not used in MVP v1.0)
CORS_ORIGIN=http://localhost:3000
